<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSMicrophoneUsageDescription</key>
	<string>Terax uses your microphone for AI voice input.</string>
	<!--
		Expose the app's Documents directory (where the ios-linuxkit rootfs lives)
		in the Files app and via Finder/iTunes file sharing. The standard,
		non-jailbreak way to give the user browsable, persistent storage: the
		Documents directory survives app updates (reinstalling the IPA over the
		existing install) and appears under Files -> "On My iPad" -> Terax.
	-->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
</dict>
</plist>
